      "parameters": {
        "operation": "executeQuery",
        "query": "=WITH results AS (SELECT status FROM social_post_targets WHERE post_id = '{{ $('Set Post to \'Publishing\'').first().json.id }}') SELECT CASE WHEN (SELECT COUNT(*) FROM results WHERE status = 'failed') > 0 THEN 'failed' ELSE 'published' END as final_status;",
